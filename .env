# Public build-time base URL used for absolute SEO / Open-Graph tags in index.html.
# Contains no secrets — safe to commit. Vite replaces %VITE_SITE_URL% at build time.
# Default: current Vercel deployment. Set to https://valanto.ch once the final domain is live
# (locally here, or as a Vercel Environment Variable).
VITE_SITE_URL=https://valanto-website.vercel.app
